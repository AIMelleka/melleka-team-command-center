# ─── Required ───────────────────────────────────────────────
# Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Shared password for the team site
TEAM_PASSWORD=your-team-password-here

# Secret for signing JWTs (make it random & long)
JWT_SECRET=generate-a-long-random-string-here

# Supabase credentials (Service Role key — not anon key)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Google Ads API ──────────────────────────────────────────
# Melleka's developer token from Google Ads API Center
# (Basic access approved — works with client OAuth tokens via per-client OAuth flow)
GOOGLE_ADS_DEVELOPER_TOKEN=

# OAuth credentials from Google Cloud Console (Web application type)
# Redirect URI: https://turbo.melleka.com/settings
# Used for client-facing OAuth AND this team tool's internal access
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Team's own refresh token for this internal tool
# (Get via: oauth.tools or OAuth Playground with scope: https://www.googleapis.com/auth/adwords)
GOOGLE_ADS_REFRESH_TOKEN=

# Melleka's MCC/Manager account ID (enables cross-client access)
# Leave blank if not using an MCC — client OAuth tokens work without it
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ─── Meta Ads API ─────────────────────────────────────────────
# Meta App from developers.facebook.com (Business type, Marketing API + Facebook Login)
# Redirect URI: https://turbo.melleka.com/settings
META_APP_ID=
META_APP_SECRET=

# ─── Supermetrics ─────────────────────────────────────────────
# API key from supermetrics.com — covers GA4, Meta, Google Ads, LinkedIn, etc.
SUPERMETRICS_API_KEY=

# ─── Email ────────────────────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=Melleka Team <team@melleka.io>

# ─── Deployment ───────────────────────────────────────────────
VERCEL_TOKEN=

# ─── Optional ────────────────────────────────────────────────
# Port (default: 3001)
PORT=3001

# Local directory for team member folders
# On Mac: /Users/aimelleka/Clients/ai/melleka/team
# On Railway: /data/team  (mount a persistent volume at /data)
LOCAL_TEAM_DIR=/Users/aimelleka/Clients/ai/melleka/team

# Path to the Melleka project codebase
# On Mac: full path below
# On Railway: leave empty or point to a git clone
MELLEKA_PROJECT_DIR=/Users/aimelleka/Clients/Main Melleka Turbo AI

# Allowed CORS origin for the client (optional, default: *)
CLIENT_ORIGIN=https://your-railway-domain.up.railway.app
